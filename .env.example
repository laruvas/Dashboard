# Backend (scripts/server.mjs) ---------------------------------------------

# JWT signing secret (HS256). Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# CORS — comma-separated list of allowed origins. Use * only for development.
CORS_ORIGIN=https://your-frontend.vercel.app

# Turso (libSQL) — leave empty to use a local SQLite file instead.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...

# Port — Render injects this automatically, defaults to 3001 in dev.
PORT=3001

# Frontend (Vite, .env.local) -----------------------------------------------

# Base URL of the deployed API.
VITE_API_URL=https://your-api.onrender.com
